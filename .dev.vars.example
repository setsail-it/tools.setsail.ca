# Copy this file to .dev.vars and fill in real values
# .dev.vars is gitignored and used by `wrangler dev` for local secrets

ANTHROPIC_API_KEY=sk-ant-...
DATAFORSEO_LOGIN=your-email@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
GEMINI_API_KEY=AIza...
ADMIN_EMAIL=jason@setsail.ca
# CF_ACCESS_TEAM_DOMAIN=setsail  # Uncomment to enable JWT validation locally

# Google Keyword Planner (optional — GKP features hidden when absent)
# GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
# GOOGLE_ADS_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_ADS_CLIENT_SECRET=your-client-secret
# GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# GOOGLE_ADS_CUSTOMER_ID=1234567890
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=9876543210  # Only if using a manager (MCC) account
